# Application
APP_NAME=audit-log-service
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit_log_db
DB_USER=audit_user
DB_PASSWORD=your_secure_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Security
API_KEY_HEADER=X-API-Key
API_KEYS=key1,key2,key3

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS (comma-separated origins, use * for all)
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
